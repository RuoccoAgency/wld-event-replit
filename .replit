modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Velocity Events"

[[workflows.workflow]]
name = "Velocity Events"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Velocity-Events && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
build = ["sh", "-c", "cd Velocity-Events && npm install && npm run build"]
run = ["sh", "-c", "cd Velocity-Events && npm start"]
deploymentTarget = "autoscale"
